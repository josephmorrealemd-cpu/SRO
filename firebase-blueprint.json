{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "An appointment or consultation request.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Patient's full name." },
        "email": { "type": "string", "format": "email", "description": "Patient's email address." },
        "phone": { "type": "string", "description": "Patient's phone number." },
        "date": { "type": "string", "format": "date", "description": "Preferred appointment date." },
        "type": { "type": "string", "description": "Type of booking (e.g., Appointment, Consultation)." },
        "condition": { "type": "string", "description": "The specific condition or area of concern." },
        "reportName": { "type": "string", "description": "Name of the uploaded imaging report file." },
        "status": { 
          "type": "string", 
          "enum": ["pending", "confirmed", "cancelled"],
          "description": "The current status of the booking." 
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created." }
      },
      "required": ["name", "email", "phone", "date", "type", "createdAt"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "A message sent through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender's name." },
        "email": { "type": "string", "format": "email", "description": "Sender's email address." },
        "subject": { "type": "string", "description": "Subject of the message." },
        "message": { "type": "string", "description": "The message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "bookings": {
      "schema": "Booking",
      "description": "Collection of appointment and consultation requests."
    },
    "contact_messages": {
      "schema": "ContactMessage",
      "description": "Collection of messages from the contact form."
    }
  }
}
